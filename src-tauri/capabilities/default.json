{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for NiceSSH",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:app:default",
    "core:path:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "updater:default"
  ]
}
