{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NiceSSH",
  "version": "0.3.13",
  "identifier": "com.nicessh.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "NiceSSH",
        "width": 1200,
        "height": 760,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "msi",
      "appimage",
      "deb",
      "rpm"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/e9ab98/NiceSSH/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBNzdCMUI5Mzc4RjA0MUMKUldRY0JJODN1YkYzS2duMmc5NS83Qzc4QTNUZDJ6cnFPOVo3TzJ0Z2RuOXE3dVZKVkZ2UExUK0sK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
